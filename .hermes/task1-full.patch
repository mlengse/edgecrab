+#!/bin/bash
+sed -i '/use super::backends::ddgs::{ImpersonateProfile, build_wreq_client, pick_random_profile};/d' crates/edgecrab-tools/src/tools/web/search/http.rs
+
+sed -i 's/wreq::Client/reqwest::Client/g' crates/edgecrab-tools/src/tools/web/search/http.rs
+
+cat << 'INNER_EOF' > /tmp/replace_http.py
+import re
+
+with open('crates/edgecrab-tools/src/tools/web/search/http.rs', 'r') as f:
+    content = f.read()
+
+content = re.sub(
+    r'pub fn build_chrome_client\(timeout_secs: u64\) -> Result<reqwest::Client, SearchError> \{[\s\S]*?\}',
+    'pub fn build_chrome_client(timeout_secs: u64) -> Result<reqwest::Client, SearchError> {\n    build_chrome_client_with_headers(timeout_secs, None, None, None)\n}',
+    content
+)
+
+content = re.sub(
+    r'pub fn build_chrome_client_with_headers\([\s\S]*?\) -> Result<reqwest::Client, SearchError> \{[\s\S]*?\}',
+    'pub fn build_chrome_client_with_headers(\n    timeout_secs: u64,\n    _referer: Option<&str>,\n    _user_agent: Option<&str>,\n    _proxy_url: Option<String>,\n) -> Result<reqwest::Client, SearchError> {\n    build_api_client(timeout_secs)\n}',
+    content
+)
+
+content = re.sub(
+    r'pub fn validate_url_legacy\(url: &str, tool: &str\) -> Result<\(\), ToolError> \{[\s\S]*?\}',
+    '',
+    content
+)
+
+with open('crates/edgecrab-tools/src/tools/web/search/http.rs', 'w') as f:
+    f.write(content)
+
