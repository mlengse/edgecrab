-        engine,
-        url,
-        referer,
-        query,
-        settings,
-        max,
-        backend,
-    } = req;
-    let mut payload: HashMap<String, String> =
-        HashMap::from([("q".into(), query.to_string()), ("b".into(), String::new())]);
-    if let Some(region) = settings.region() {
-        payload.insert("kl".into(), region.to_string());
