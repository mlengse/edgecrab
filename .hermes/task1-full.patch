-            )
-            .await?;
-
-        if parse::bing_page_reports_no_results(&html) {
-            break;
-        }
-
-        if let Some(batch) = process_page(
-            DdgsEngine::Bing,
-            &html,
-            max.saturating_sub(results.len()),
-            backend,
-        )? {
-            let n = batch.len();
-            results.extend(batch);
-            if results.len() >= max || n == 0 {
-                break;
-            }
