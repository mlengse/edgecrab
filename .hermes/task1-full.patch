-    let mut results = Vec::new();
-
-    for _ in 0..MAX_PAGES {
-        let form: Vec<(&str, &str)> = payload
-            .iter()
-            .map(|(k, v)| (k.as_str(), v.as_str()))
-            .collect();
-
-        let html = session
-            .post_form(engine, backend, url, referer, &form)
